*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff: (agar kerak bo'lsa)
instance/
.webassets-cache

# Environments
.env
.venv
env/
venv/
ENV/

# PyCharm / IntelliJ IDEA
.idea/
*.iml
*.iws
.idea_modules/

# VS Code
.vscode/

# migrations/ papkasini ignore qilmang!
# Faqat ichidagi kesh fayllar ketsa bo'ladi:
**/migrations/__pycache__/

# OS xizmat fayllari
.DS_Store
Thumbs.db

